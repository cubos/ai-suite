## Embeddings

```typescript
// Single text
const result = await aiSuite.createEmbedding(
  'openai/text-embedding-3-small',
  { content: 'Hello, world!' },
);

if (result.success) {
  console.log(result.content[0]); // number[] — embedding vector
}

// Multiple texts
const result = await aiSuite.createEmbedding(
  'openai/text-embedding-3-small',
  { content: ['Text 1', 'Text 2', 'Text 3'] },
);

// With custom dimensions (OpenAI)
const result = await aiSuite.createEmbedding(
  'openai/text-embedding-3-large',
  { content: 'Hello' },
  { dimensions: 256 },
);

// With task type (Gemini)
const result = await aiSuite.createEmbedding(
  'gemini/gemini-embedding-001',
  { content: 'Search query' },
  { taskType: 'RETRIEVAL_QUERY' }, // RETRIEVAL_QUERY | RETRIEVAL_DOCUMENT | SEMANTIC_SIMILARITY | CLASSIFICATION | CLUSTERING | QUESTION_ANSWERING | FACT_VERIFICATION
);
```

