## Response Types

### SuccessChatCompletion

```typescript
{
  success: true;
  id: string;
  object: 'chat.completion';
  created: number;          // Unix timestamp
  model: string;
  content: string | null;   // Text response
  content_object: Record<string, unknown>; // Parsed JSON (for json_schema / json_object)
  usage?: {
    input_tokens: number;
    output_tokens: number;
    total_tokens: number;
    cached_tokens?: number;
    reasoning_tokens?: number; // o1/o3/Grok reasoning
    thoughts_tokens?: number;  // Gemini thinking
  };
  tools?: {
    id: string;
    type: 'function';
    name: string;
    content: Record<string, unknown>; // parsed arguments
    rawContent: string;
  }[];
  execution_time?: number;  // milliseconds
  metadata?: Record<string, unknown>;
}
```

### ErrorAISuite

```typescript
{
  success: false;
  created: number;
  model: string;
  error: string;            // Human-readable error message
  tag: 'InvalidAuth' | 'InvalidRequest' | 'InvalidModel' | 'RateLimitExceeded' | 'ServerError' | 'ServerOverloaded' | 'Unknown';
  raw: Error;
  execution_time?: number;
}
```

### ResultEmbedding (success)

```typescript
{
  success: true;
  object: 'list';
  model: string;
  content: number[][];      // Array of embedding vectors
  usage: {
    input_tokens: number;
    output_tokens: number;
    total_tokens: number;
  };
  metadata?: Record<string, unknown>;
}
```

