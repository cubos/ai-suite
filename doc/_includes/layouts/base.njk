<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}AI-Suite</title>
  <meta name="description" content="{{ description or 'AI-Suite - Unified TypeScript interface for multiple AI providers' }}">

  <link rel="icon" type="image/svg+xml" href="{{ '/favicon.svg' | url }}">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #4f46e5;
      --text: #1e293b;
      --text-light: #64748b;
      --border: #e2e8f0;
      --bg: #ffffff;
      --bg-light: #f8fafc;
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--text);
      line-height: 1.6;
      background: var(--bg);
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* Header */
    header {
      border-bottom: 1px solid var(--border);
      background: var(--bg);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 1rem 0;
    }

    .logo {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      text-decoration: none;
    }

    .logo span {
      color: var(--primary);
    }

    nav {
      flex: 1;
    }

    nav ul {
      display: flex;
      list-style: none;
      gap: 0.25rem;
    }

    nav a {
      color: var(--text-light);
      text-decoration: none;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-size: 0.9375rem;
      transition: all 0.15s;
    }

    nav a:hover {
      color: var(--primary);
      background: var(--bg-light);
    }

    /* Main */
    main {
      padding: 3rem 0;
      min-height: calc(100vh - 200px);
    }

    /* Footer */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem 0;
      text-align: center;
      color: var(--text-light);
      font-size: 0.875rem;
    }

    /* Typography */
    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: var(--text);
    }

    h2 {
      font-size: 1.75rem;
      font-weight: 600;
      margin: 2.5rem 0 1rem;
      color: var(--text);
    }

    h3 {
      font-size: 1.375rem;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
      color: var(--text);
    }

    h4 {
      font-size: 1.125rem;
      font-weight: 600;
      margin: 1.5rem 0 0.5rem;
      color: var(--text);
    }

    p {
      margin-bottom: 1rem;
      color: var(--text-light);
    }

    a {
      color: var(--primary);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    ul, ol {
      margin-bottom: 1rem;
      padding-left: 2rem;
    }

    li {
      margin-bottom: 0.5rem;
      color: var(--text-light);
    }

    /* Code */
    code {
      font-family: 'SF Mono', 'Monaco', 'Menlo', monospace;
      font-size: 0.875em;
    }

    pre {
      background: var(--bg-light);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background: none;
      padding: 0;
      border: none;
    }

    :not(pre) > code {
      background: var(--bg-light);
      padding: 0.2em 0.4em;
      border-radius: 3px;
      border: 1px solid var(--border);
    }

    /* Tables */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }

    th, td {
      padding: 0.75rem;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }

    th {
      background: var(--bg-light);
      font-weight: 600;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .container {
        padding: 0 1rem;
      }

      nav ul {
        gap: 0;
      }

      nav a {
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
      }

      h1 {
        font-size: 1.875rem;
      }

      h2 {
        font-size: 1.5rem;
      }
    }
  </style>

  {% block head %}{% endblock %}
</head>
<body>
  <header>
    <div class="container">
      <div class="header-content">
        <a href="{{ '/' | url }}" class="logo">AI-<span>Suite</span></a>
        <nav>
          <ul>
            <li><a href="{{ '/getting-started/' | url }}">Getting Started</a></li>
            <li><a href="{{ '/providers/' | url }}">Providers</a></li>
            <li><a href="{{ '/api-reference/' | url }}">API</a></li>
            <li><a href="{{ '/advanced-usage/' | url }}">Advanced</a></li>
            <li><a href="{{ '/examples/' | url }}">Examples</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </header>

  <main>
    {% block content %}
      {{ content | safe }}
    {% endblock %}
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2025 AI-Suite | MIT License</p>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/typescript.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/bash.min.js"></script>
  <script>hljs.highlightAll();</script>

  {% block scripts %}{% endblock %}
</body>
</html>
