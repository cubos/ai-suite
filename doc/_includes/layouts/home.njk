---
layout: base.njk
---

{% block head %}
<style>
  .hero {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--text-light);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .cta {
    margin: 2rem 0;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--primary);
    color: white;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
  }

  .btn:hover {
    background: #4338ca;
    text-decoration: none;
  }

  .content {
    max-width: 800px;
    margin: 0 auto;
  }
</style>
{% endblock %}

{% block content %}
<div class="container">
  <div class="content">
    {{ content | safe }}
  </div>
</div>
{% endblock %}
