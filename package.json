{
  "name": "@cubos/ai-suite",
  "author": "Joshua Passos",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --trace-deprecation --watch src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "vitest",
    "docs:start": "eleventy --serve --input=./doc --config=./doc/.eleventy.cjs",
    "docs:build": "eleventy --input=./doc --config=./doc/.eleventy.cjs"
  },
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "package.json"
  ],
  "keywords": [],
  "license": "MIT",
  "description": "All ai providers in one place",
  "packageManager": "pnpm@10.4.1",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@biomejs/biome": "2.2.4",
    "@cubos/eslint-config": "^2.2.0",
    "globals": "^16.3.0",
    "markdown-it": "^14.0.0",
    "markdown-it-anchor": "^8.6.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.70.0",
    "@google/genai": "^1.43.0",
    "@types/node": "^22.15.18",
    "dotenv": "^16.5.0",
    "gemini-zod": "^0.1.2",
    "json5": "^2.2.3",
    "langfuse": "^3.38.5",
    "openai": "6.9.1",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.3",
    "zod-to-json-schema": "^3.24.6"
  }
}